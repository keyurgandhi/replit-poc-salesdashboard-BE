{
  "name": "sales-dashboard-backend",
  "version": "1.0.0",
  "description": "Express 5 + Drizzle ORM API server for the Sales Dashboard",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env ./src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts",
    "seed": "tsx ./src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
